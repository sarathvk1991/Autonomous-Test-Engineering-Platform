{
  "registryVersion": "1.0.0",
  "phase": "PHASE_1_REQUIREMENT_INTELLIGENCE",
  "description": "Declarative registry of ingestion sources for the Requirement Intelligence Layer. Each entry maps a source to its connector and mapper. The registry is configuration only and intentionally contains no business logic. The ingestion mode is NOT declared per source: it is selected globally by the EXECUTION_MODE environment variable (FILE or API) and stamped onto every source by the RegistryLoader; defaults.inputMode below records only the fallback used when EXECUTION_MODE is unset. API-mode base URLs and credentials are never stored here: the connection block names the environment variables that hold them (see .env.example).",
  "defaults": {
    "inputMode": "FILE",
    "enabled": false
  },
  "supportedInputModes": [
    "FILE",
    "API"
  ],
  "sources": [
    {
      "sourceId": "jira",
      "sourceName": "JIRA",
      "sourceType": "REQUIREMENT_SOURCE",
      "sourceCategory": "FUNCTIONAL",
      "schemaVersion": "1.0",
      "enabled": true,
      "connectorClass": "requirement_intelligence.connectors.jira.connector.JiraConnector",
      "mapperClass": "requirement_intelligence.mappers.jira_mapper.JiraMapper",
      "inputPath": "input/jira/jira-issues.json",
      "outputCategory": "FUNCTIONAL_REQUIREMENT",
      "priority": 1,
      "requiredForPhase": true,
      "connection": {
        "authType": "basic",
        "baseUrlEnv": "JIRA_BASE_URL",
        "authUserEnv": "JIRA_EMAIL",
        "authTokenEnv": "JIRA_API_TOKEN",
        "projectKeyEnv": "JIRA_PROJECT_KEY"
      },
      "api": {
        "timeoutSeconds": 30,
        "retry": {
          "maxAttempts": 3,
          "backoffSeconds": 1.0,
          "maxBackoffSeconds": 30.0
        },
        "pagination": {
          "pageSize": 50
        },
        "jql": "issuetype in (Story, Bug, Epic)",
        "incremental": {
          "enabled": false,
          "jql": "updated >= -30d"
        }
      },
      "description": "Functional requirements, epics, stories, and defects sourced from JIRA. FILE mode ingests an exported issue dump; API mode fetches live via the JIRA REST API using credentials from the environment. The api.jql restriction scopes retrieval to the three issue types JiraMapper canonicalises (Story, Bug, Epic); JIRA issues of any other type (e.g. Task, Sub-task) are not ingested."
    },
    {
      "sourceId": "owasp_zap",
      "sourceName": "OWASP ZAP",
      "sourceType": "DAST_SOURCE",
      "sourceCategory": "SECURITY",
      "schemaVersion": "1.0",
      "enabled": true,
      "connectorClass": "requirement_intelligence.connectors.zap.connector.ZapConnector",
      "mapperClass": "requirement_intelligence.mappers.zap_mapper.ZapMapper",
      "inputPath": "input/zap/zap-alerts.json",
      "outputCategory": "SECURITY_FINDING",
      "priority": 2,
      "requiredForPhase": true,
      "connection": {
        "authType": "apiKey",
        "baseUrlEnv": "ZAP_BASE_URL",
        "apiKeyEnv": "ZAP_API_KEY",
        "targetUrlEnv": "ZAP_TARGET_URL"
      },
      "api": {
        "timeoutSeconds": 30,
        "retry": {
          "maxAttempts": 3,
          "backoffSeconds": 1.0,
          "maxBackoffSeconds": 30.0
        },
        "pagination": {
          "pageSize": 100
        }
      },
      "description": "Dynamic application security testing (DAST) alerts from OWASP ZAP. FILE mode ingests an exported alert report; API mode fetches live via the ZAP daemon REST API using the API key from the environment."
    },
    {
      "sourceId": "sonarqube",
      "sourceName": "SonarQube",
      "sourceType": "SAST_SOURCE",
      "sourceCategory": "QUALITY",
      "schemaVersion": "1.0",
      "enabled": true,
      "connectorClass": "requirement_intelligence.connectors.sonarqube.connector.SonarQubeConnector",
      "mapperClass": "requirement_intelligence.mappers.sonar_mapper.SonarMapper",
      "inputPath": "input/sonar/sonar-issues.json",
      "outputCategory": "QUALITY_FINDING",
      "priority": 3,
      "requiredForPhase": true,
      "connection": {
        "authType": "token",
        "baseUrlEnv": "SONAR_BASE_URL",
        "authTokenEnv": "SONAR_TOKEN",
        "projectKeyEnv": "SONAR_PROJECT_KEY",
        "branchEnv": "SONAR_BRANCH"
      },
      "api": {
        "timeoutSeconds": 30,
        "retry": {
          "maxAttempts": 3,
          "backoffSeconds": 1.0,
          "maxBackoffSeconds": 30.0
        },
        "pagination": {
          "pageSize": 100
        },
        "incremental": {
          "enabled": false,
          "createdAfter": ""
        }
      },
      "description": "Static analysis (SAST) and code quality issues from SonarQube. FILE mode ingests an exported issues report; API mode fetches live via the SonarQube Web API using the token from the environment."
    }
  ]
}
