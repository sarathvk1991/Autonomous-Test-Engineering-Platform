{
  "$schema": "./source-registry.schema.json",
  "registryVersion": "1.0.0",
  "phase": "PHASE_1_REQUIREMENT_INTELLIGENCE",
  "description": "Declarative registry of ingestion sources for the Requirement Intelligence Layer. Each entry maps a source to its connector and parser. The registry is configuration only and intentionally contains no business logic.",
  "defaults": {
    "inputMode": "FILE",
    "enabled": false
  },
  "supportedInputModes": [
    "FILE",
    "API"
  ],
  "sources": [
    {
      "sourceId": "jira",
      "sourceName": "JIRA",
      "sourceType": "REQUIREMENT_SOURCE",
      "sourceCategory": "FUNCTIONAL",
      "schemaVersion": "1.0",
      "enabled": true,
      "connectorClass": "requirement_intelligence.connectors.jira.connector.JiraConnector",
      "mapperClass": "requirement_intelligence.mappers.jira_mapper.JiraMapper",
      "parserClass": "requirement_intelligence.parsers.jira.parser.JiraParser",
      "inputMode": "FILE",
      "inputPath": "input/jira/jira-issues.json",
      "outputCategory": "FUNCTIONAL_REQUIREMENT",
      "priority": 1,
      "requiredForPhase": true,
      "connection": {
        "mode": "FILE",
        "baseUrl": "",
        "authType": ""
      },
      "description": "Functional requirements, epics, stories, and defects sourced from JIRA. Phase 1 ingests an exported issue dump in FILE mode."
    },
    {
      "sourceId": "owasp_zap",
      "sourceName": "OWASP ZAP",
      "sourceType": "DAST_SOURCE",
      "sourceCategory": "SECURITY",
      "schemaVersion": "1.0",
      "enabled": true,
      "connectorClass": "requirement_intelligence.connectors.zap.connector.ZapConnector",
      "mapperClass": "requirement_intelligence.mappers.zap_mapper.ZapMapper",
      "parserClass": "requirement_intelligence.parsers.zap.parser.ZapParser",
      "inputMode": "FILE",
      "inputPath": "input/zap/zap-alerts.json",
      "outputCategory": "SECURITY_FINDING",
      "priority": 2,
      "requiredForPhase": true,
      "connection": {
        "mode": "FILE",
        "baseUrl": "",
        "authType": ""
      },
      "description": "Dynamic application security testing (DAST) alerts from OWASP ZAP. Phase 1 ingests an exported alert report in FILE mode."
    },
    {
      "sourceId": "sonarqube",
      "sourceName": "SonarQube",
      "sourceType": "SAST_SOURCE",
      "sourceCategory": "QUALITY",
      "schemaVersion": "1.0",
      "enabled": true,
      "connectorClass": "requirement_intelligence.connectors.sonarqube.connector.SonarQubeConnector",
      "mapperClass": "requirement_intelligence.mappers.sonar_mapper.SonarMapper",
      "parserClass": "requirement_intelligence.parsers.sonarqube.parser.SonarQubeParser",
      "inputMode": "FILE",
      "inputPath": "input/sonar/sonar-issues.json",
      "outputCategory": "QUALITY_FINDING",
      "priority": 3,
      "requiredForPhase": true,
      "connection": {
        "mode": "FILE",
        "baseUrl": "",
        "authType": ""
      },
      "description": "Static analysis (SAST) and code quality issues from SonarQube. Phase 1 ingests an exported issues report in FILE mode."
    }
  ]
}