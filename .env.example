# ===========================================================================
# Autonomous Test Engineering Platform — Environment Template
# ---------------------------------------------------------------------------
# Copy to `.env` and fill in real values.  NEVER commit a populated `.env`.
#   cp .env.example .env
# All variables are loaded via pydantic-settings (see app/core/settings.py).
# ===========================================================================

# --- Application ------------------------------------------------------------
APP_NAME="Autonomous Test Engineering Platform"
APP_ENV=local                       # local | dev | staging | prod
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                     # true => structured JSON logs

# --- Azure OpenAI -----------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o                # chat/analysis deployment name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_TIMEOUT_SECONDS=60
AZURE_OPENAI_MAX_RETRIES=3

# --- Jira Connector ---------------------------------------------------------
JIRA_BASE_URL=https://<your-org>.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT_KEY=

# --- SonarQube Connector ----------------------------------------------------
SONARQUBE_BASE_URL=https://sonarqube.example.com
SONARQUBE_TOKEN=
SONARQUBE_DEFAULT_PROJECT_KEY=

# --- OWASP ZAP Connector ----------------------------------------------------
ZAP_BASE_URL=http://localhost:8080
ZAP_API_KEY=

# --- Database (PostgreSQL — future phase) ----------------------------------
DATABASE_URL=postgresql+psycopg://atep:atep@localhost:5432/atep
DATABASE_POOL_SIZE=5
DATABASE_ECHO=false
