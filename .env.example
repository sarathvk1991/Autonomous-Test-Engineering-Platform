# ===========================================================================
# Autonomous Test Engineering Platform — Environment Template
# ---------------------------------------------------------------------------
# Canonical template for every environment variable the platform can use.
# Copy to `.env` and fill in real values:   cp .env.example .env
#
# This template contains PLACEHOLDER VALUES ONLY.
# Never put real secrets, credentials, tokens, API keys, passwords, or
# private endpoints in this file — it is committed to version control.
# See the Security Guidelines at the bottom of this file.
# ===========================================================================


# ---------------------------------------------------------------------------
# Section 1 — Project Information
# ---------------------------------------------------------------------------
# Human-readable platform name (informational only).
PROJECT_NAME=Autonomous Test Engineering Platform
# Runtime environment: development | staging | production
PROJECT_ENV=development
# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ---------------------------------------------------------------------------
# Section 2 — Google Gemini (active provider)
# ---------------------------------------------------------------------------
# API key issued by Google AI Studio (https://aistudio.google.com/).
# Required for the Gemini provider; read from the environment at runtime.
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
# Default Gemini model used for generation. Override to switch models
# (e.g. gemini-2.5-flash for faster / lower-cost runs).
GEMINI_MODEL=gemini-2.5-pro


# ---------------------------------------------------------------------------
# Section 3 — Azure OpenAI (FUTURE — reserved for future migration)
# ---------------------------------------------------------------------------
# Placeholders only. Not used in Phase 1. Reserved for migrating the active
# provider to Azure OpenAI without changing the rest of the platform.
# Base endpoint of your Azure OpenAI resource.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# Azure OpenAI API key.
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# Azure OpenAI REST API version (e.g. 2024-06-01).
AZURE_OPENAI_API_VERSION=your_api_version
# Name of the model deployment to invoke.
AZURE_OPENAI_DEPLOYMENT=your_deployment_name


# ---------------------------------------------------------------------------
# Section 4 — JIRA (LIVE API MODE)
# ---------------------------------------------------------------------------
# Used ONLY when the JIRA connector runs in live API mode
# (inputMode "API" in source-registry.json).
# Base URL of your Atlassian JIRA instance.
JIRA_BASE_URL=https://your-company.atlassian.net
# Account email associated with the API token.
JIRA_EMAIL=your_email@example.com
# JIRA API token (treat as a secret).
JIRA_API_TOKEN=your_jira_api_token_here
# Default project key to ingest from.
JIRA_PROJECT_KEY=YOURPROJECT


# ---------------------------------------------------------------------------
# Section 5 — SonarQube (LIVE API MODE)
# ---------------------------------------------------------------------------
# Used ONLY when the SonarQube connector runs in live API mode
# (inputMode "API" in source-registry.json).
# Base URL of your SonarQube server.
SONAR_BASE_URL=http://localhost:9000
# SonarQube user/access token (treat as a secret).
SONAR_TOKEN=your_sonar_token_here
# Project key to pull quality findings for.
SONAR_PROJECT_KEY=your_project_key
# Optional analysis branch to scope issues to (leave empty for the default).
SONAR_BRANCH=


# ---------------------------------------------------------------------------
# Section 6 — OWASP ZAP (LIVE API MODE)
# ---------------------------------------------------------------------------
# Used ONLY when the OWASP ZAP connector runs in live API mode
# (inputMode "API" in source-registry.json).
# Base URL of the running ZAP daemon / API.
ZAP_BASE_URL=http://localhost:8080
# ZAP API key (treat as a secret).
ZAP_API_KEY=your_zap_api_key_here
# Optional target site to scope alerts to (leave empty for all alerts).
ZAP_TARGET_URL=


# ---------------------------------------------------------------------------
# Section 7 — Analysis Configuration (FUTURE)
# ---------------------------------------------------------------------------
# These correspond to future AnalysisConfiguration capabilities. Only
# temperature is consumed today; the rest are reserved for later phases.
# Default sampling temperature (0.0 = deterministic; range 0.0–2.0).
DEFAULT_TEMPERATURE=0.0
# Per-request provider timeout in seconds (future).
DEFAULT_PROVIDER_TIMEOUT=30
# Number of retry attempts on failure (future; 0 = no retries).
DEFAULT_MAX_RETRY_ATTEMPTS=0
# Whether streaming responses are requested (future).
ENABLE_STREAMING=false
# Whether a structured response schema is enforced (future).
ENABLE_RESPONSE_SCHEMA=false


# ---------------------------------------------------------------------------
# Section 8 — Output Locations
# ---------------------------------------------------------------------------
# Directory containing input artifacts for ingestion.
INPUT_DIRECTORY=input
# Directory where generated outputs are written.
OUTPUT_DIRECTORY=output
# Directory where reports are written.
REPORT_DIRECTORY=reports


# ===========================================================================
# Section 9 — Security Guidelines
# ---------------------------------------------------------------------------
# • Never commit real credentials — this file must hold placeholders only.
# • Always keep `.env` in `.gitignore` (it already is); never commit `.env`.
# • Use `.env.example` strictly as a template — copy it to `.env` locally.
# • Rotate API keys and tokens regularly, and immediately on suspected leak.
# • Use least privilege — scope keys/tokens to the minimum access required.
# • Never log secrets; keep them out of source, tickets, and chat.
# ===========================================================================
